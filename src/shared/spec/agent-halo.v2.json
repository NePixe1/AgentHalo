{
  "contractVersion": 2,
  "releaseVersion": "0.13.0",
  "algorithms": {
    "breath": "livingBreathV1",
    "attentionPulse": "attentionDoublePulseV1",
    "errorPulse": "errorDoubleFlashV1",
    "colorInterpolation": "linearSrgbV1",
    "gapRepulsion": "magneticRepulsionV1"
  },
  "states": {
    "idle": {
      "priority": 5,
      "label": "READY",
      "color": [113, 132, 140],
      "breath": {"period": 6.8, "visualMaximum": 0.40, "visualMinimum": 0.18, "poweredMaximum": 0.0, "poweredMinimum": 0.0, "brightShare": 0.50},
      "orbit": {"velocity": 27, "envelopePeriod": 7.6, "driftAmplitude": 5.2, "driftPeriod": 4.8, "inertiaDamping": 0.62},
      "coreWhite": 0.82,
      "glowGain": 1.0
    },
    "thinking": {
      "priority": 3,
      "label": "THINKING",
      "color": [226, 170, 31],
      "breath": {"period": 5.5, "visualMaximum": 1.0, "visualMinimum": 0.26, "poweredMaximum": 1.0, "poweredMinimum": 0.18, "brightShare": 0.70},
      "orbit": {"velocity": 78, "envelopePeriod": 4.2, "driftAmplitude": 7.0, "driftPeriod": 3.6, "inertiaDamping": 0.66},
      "coreWhite": 0.90,
      "glowGain": 1.13
    },
    "working": {
      "priority": 2,
      "label": "EXECUTING",
      "color": [52, 158, 199],
      "breath": {"period": 7.2, "visualMaximum": 1.0, "visualMinimum": 0.22, "poweredMaximum": 1.0, "poweredMinimum": 0.16, "brightShare": 0.78},
      "orbit": {"velocity": 106, "envelopePeriod": 2.2, "driftAmplitude": 8.5, "driftPeriod": 2.8, "inertiaDamping": 0.72},
      "coreWhite": 0.86,
      "glowGain": 1.07
    },
    "done": {
      "priority": 4,
      "label": "COMPLETE",
      "color": [38, 198, 108],
      "breath": {"period": 9.2, "visualMaximum": 0.92, "visualMinimum": 0.22, "poweredMaximum": 0.84, "poweredMinimum": 0.09, "brightShare": 0.76},
      "orbit": {"velocity": 38, "envelopePeriod": 8.5, "driftAmplitude": 4.2, "driftPeriod": 5.5, "inertiaDamping": 0.58},
      "coreWhite": 0.84,
      "glowGain": 1.0
    },
    "attention": {
      "priority": 1,
      "label": "NEEDS YOU",
      "color": [142, 108, 236],
      "breath": {"period": 5.8, "visualMaximum": 1.0, "visualMinimum": 0.18, "poweredMaximum": 1.0, "poweredMinimum": 0.10, "brightShare": 0.44},
      "orbit": {"velocity": 46, "envelopePeriod": 4.1, "driftAmplitude": 6.5, "driftPeriod": 3.3, "inertiaDamping": 0.76},
      "coreWhite": 0.82,
      "glowGain": 1.0
    },
    "error": {
      "priority": 0,
      "label": "INTERRUPTED",
      "color": [218, 50, 86],
      "breath": {"period": 1.55, "visualMaximum": 1.0, "visualMinimum": 0.04, "poweredMaximum": 1.0, "poweredMinimum": 0.0, "brightShare": 0.22},
      "orbit": {"velocity": 60, "envelopePeriod": 1.75, "driftAmplitude": 7.5, "driftPeriod": 2.6, "inertiaDamping": 0.84},
      "coreWhite": 0.91,
      "glowGain": 1.12
    }
  },
  "transitions": {
    "dimEnd": 0.36,
    "colorBlendEnd": 0.58,
    "lowPowered": 0.08,
    "durationByTarget": {"idle": 1.78, "thinking": 1.68, "working": 1.48, "done": 1.72, "attention": 1.02, "error": 0.92}
  },
  "attentionPulse": {
    "period": 5.8,
    "first": {"center": 0.16, "width": 0.095, "strength": 1.0},
    "second": {"center": 0.38, "width": 0.11, "strength": 0.82},
    "livingBase": 0.08,
    "livingAmplitude": 0.05,
    "livingPhase": 0.18
  },
  "errorPresentations": {
    "names": ["flashing", "bright", "dim"],
    "brightPower": 0.92,
    "dimPower": 0.04,
    "flashPeriod": 1.55,
    "first": {"center": 0.12, "width": 0.055},
    "second": {"center": 0.34, "width": 0.065}
  },
  "gapMotion": {
    "minimumSeparationDegrees": 40,
    "maximumSeparationDegrees": 150,
    "repulsionSpeedMinimum": 14,
    "repulsionSpeedMaximum": 92,
    "repulsionDurationFactor": 1.42,
    "repulsionReferenceSpeed": 72,
    "repulsionDurationMinimum": 1.28,
    "repulsionDurationMaximum": 3.05,
    "exitVelocityScale": 0.42,
    "exitVelocityMinimum": 9,
    "exitVelocityMaximum": 38
  },
  "eventRules": {
    "taskStartExact": ["task_started", "user_message"],
    "taskCompleteExact": ["task_complete"],
    "attentionContains": ["approval", "request_user", "needs_input"],
    "fatalExact": ["turn_aborted", "turn_failed", "task_failed", "task_cancelled", "task_interrupted", "fatal_error"],
    "toolOutputExact": ["function_call_output", "custom_tool_call_output", "tool_search_output"],
    "toolCallExact": ["custom_tool_call", "web_search_call", "tool_search_call"]
  },
  "actionRules": [
    {"containsAny": ["shell", "command"], "label": "Running command"},
    {"containsAny": ["apply_patch", "edit", "write"], "label": "Editing files"},
    {"containsAny": ["web_search", "search_query"], "label": "Searching"},
    {"containsAny": ["tool_search"], "label": "Finding a tool"},
    {"containsAny": ["browser"], "label": "Using browser"},
    {"containsAny": ["image"], "label": "Working with image"},
    {"containsAny": ["plan"], "label": "Updating plan"}
  ],
  "failureRules": [
    {"kind": "authentication", "detail": "认证已失效", "containsAny": ["authentication failed", "unauthorized", "invalid token", "sign in again"]},
    {"kind": "quota", "detail": "额度已用尽", "containsAny": ["rate limit reached", "usage limit", "quota exceeded", "rate_limit_reached"]},
    {"kind": "service", "detail": "服务暂时不可用", "containsAny": ["service unavailable", "server overloaded", "overloaded", "bad gateway"]},
    {"kind": "network", "detail": "连接 Codex 失败", "containsAny": ["connection failed", "network error", "connection aborted", "request timed out", "connect timeout"]}
  ],
  "rateLimit": {
    "marker": "\"rate_limits\"",
    "containerPaths": [["payload", "rate_limits"], ["payload", "info", "rate_limits"]],
    "primaryPath": ["primary", "used_percent"],
    "secondaryPath": ["secondary", "used_percent"],
    "tailBytes": 1048576,
    "recentFileCount": 16,
    "recentLineCount": 300
  },
  "settings": {
    "contractVersion": 1,
    "sharedFields": ["paused", "installedAt", "acknowledged", "acknowledgedErrorAt"],
    "platformFields": {
      "windows": ["hasPosition", "left", "top", "alwaysOnTop", "haloScalePercent"],
      "macos": ["hasPosition", "left", "top", "alwaysOnTop"]
    }
  },
  "platformExtensions": {
    "windows": {
      "materialModel": "darkLitTubeWhiteCoreV1",
      "completionDoubleFlash": true
    },
    "macos": {
      "materialModel": "darkLitTubeWhiteCoreV1",
      "completionDoubleFlash": true,
      "refreshDriver": "displayLinkV1",
      "contextMenu": "fullControlMenuV1"
    }
  }
}
